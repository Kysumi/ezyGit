{
  "name": "ezygit",
  "version": "0.1.0",
  "author": {
    "name": "Scott Maunder"
  },
  "private": true,
  "dependencies": {
    "@blueprintjs/core": "^3.31.0",
    "@blueprintjs/select": "^3.13.7",
    "@reduxjs/toolkit": "^1.4.0",
    "@testing-library/jest-dom": "^4.2.4",
    "@testing-library/react": "^9.5.0",
    "@testing-library/user-event": "^7.2.1",
    "@types/node": "^14.6.2",
    "@types/react": "^16.9.48",
    "@types/react-dom": "^16.9.8",
    "@types/react-list": "^0.8.5",
    "@types/react-redux": "^7.1.9",
    "@types/styled-components": "^5.1.2",
    "classnames": "^2.2.6",
    "concurrently": "^5.3.0",
    "electron-is-dev": "^1.2.0",
    "isomorphic-git": "^1.7.4",
    "lodash": "^4.17.20",
    "re-resizable": "^6.5.4",
    "react": "^16.13.1",
    "react-diff-view": "^2.4.4",
    "react-dom": "^16.13.1",
    "react-hotkeys": "^2.0.0",
    "react-list": "^0.8.15",
    "react-redux": "^7.2.1",
    "react-scripts": "^3.4.3",
    "redux-thunk": "^2.3.0",
    "styled-components": "^5.1.1",
    "typescript": "^4.0.2",
    "unidiff": "^1.0.2",
    "wait-on": "^5.2.0"
  },
  "main": "./electron/main.js",
  "homepage": "./",
  "build": {
    "extraMetadata": {
      "main": "build/electron/main.js"
    },
    "files": [
      "build/**/*",
      "node_modules/**/*"
    ],
    "publish": {
      "provider": "github",
      "repo": "ezyGit",
      "owner": "Maunder"
    },
    "win": {
      "target": "portable"
    }
  },
  "scripts": {
    "start": "react-scripts start",
    "build": "react-scripts build",
    "test": "react-scripts test",
    "eject": "react-scripts eject",
    "ebuild": "npm run build && robocopy electron build/electron /S && node_modules\\.bin\\electron-builder build -w",
    "dev": "concurrently \"npm start\" \"wait-on http://localhost:3000 && electron .\""
  },
  "eslintConfig": {
    "extends": "react-app"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "devDependencies": {
    "electron-builder": "^22.8.0",
    "prettier": "^2.1.1",
    "electron-devtools-installer": "^3.1.1",
    "electron": "^9.2.1"
  }
}
